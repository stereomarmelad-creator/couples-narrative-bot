# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Supabase project URL and service role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# OpenRouter API key (openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Server-side encryption secret for AES-256-GCM key derivation (min 32 chars recommended)
ENCRYPTION_SECRET=change_this_to_a_long_random_string_min_32_chars

# Public webhook URL (your deploy URL), e.g. https://your-app.onrender.com
WEBHOOK_URL=https://your-app.onrender.com
